# PostgreSQL connection. The default value matches docker-compose.yml.
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=car_damage_claims;Username=car_damage_claims;Password=car_damage_claims

# JWT override for non-local environments.
Jwt__Key=change-me-to-a-long-random-signing-key

# OpenAI is optional. Leave empty to use mock image analysis locally.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OpenAi__BaseUrl=https://api.openai.com/v1
OpenAi__ProxyUrl=

# SMTP is optional. Leave empty to use mock email sending locally.
Email__Host=
Email__Port=587
Email__Username=
Email__Password=
Email__FromName=Car Damage Claims AI
Email__FromEmail=
